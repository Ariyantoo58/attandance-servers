generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  password        String
  email           String    @unique
  role            String    @default("EMPLOYEE")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  employeeId      String?   @unique
  refreshToken    String?
  refreshTokenExp DateTime?
  pushToken       String?
  employee        Employee? @relation(fields: [employeeId], references: [id])
}

model Employee {
  id              String         @id @default(uuid())
  employeeNumber  String?        @unique
  name            String
  gender          String?
  dateOfBirth     DateTime?
  phoneNumber     String?
  address         String?
  avatarUrl       String?
  designation     String?
  salary          Float?
  joinDate        DateTime?
  status          String?        @default("ACTIVE")
  study           String?
  experience      String?
  achievement     String?
  marks10         String?
  marks12         String?
  graduationMarks String?
  documents       String?
  ptkpStatus      String?        @default("TK0")
  departmentId    String?
  positionId      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  attendance      Attendance[]
  position        Position?      @relation(fields: [positionId], references: [id])
  department      Department?    @relation(fields: [departmentId], references: [id])
  faceMetadata    FaceMetadata?
  notifications   Notification[]
  payrolls        Payroll[]
  tasks           Task[]
  timeOffs        TimeOff[]
  user            User?
  attendanceCorrections AttendanceCorrection[]
  ledTeams        Team[]         @relation("TeamLeader")
  teams           TeamMember[]
  overtimes       Overtime[]
  kpiReviews      KpiReview[]
  reimbursements  Reimbursement[]
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Position {
  id          String     @id @default(uuid())
  title       String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Attendance {
  id               String    @id @default(uuid())
  employeeId       String
  clockIn          DateTime  @default(now())
  clockOut         DateTime?
  date             DateTime  @default(now())
  status           String    @default("PRESENT")
  clockInLocation  String?
  clockInLat       Float?
  clockInLng       Float?
  clockOutLocation String?
  clockOutLat      Float?
  clockOutLng      Float?
  deviceInfo       String?
  isCorrected      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  employee         Employee  @relation(fields: [employeeId], references: [id])
  corrections      AttendanceCorrection[]

  @@unique([employeeId, date])
}

model TimeOff {
  id          String   @id @default(uuid())
  employeeId  String
  title       String
  description String?
  fromdate    DateTime
  todate      DateTime
  type        String   @default("ANNUAL")
  status      String   @default("SUBMITTED")
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model Task {
  id          String   @id @default(uuid())
  employeeId  String?
  teamId      String?
  title       String
  description String?
  date        DateTime @default(now())
  dueDate     DateTime?
  completedAt DateTime?
  status      String   @default("PENDING")
  priority    String   @default("MEDIUM")
  progress    Int      @default(0)
  category    String?  @default("GENERAL")
  weight      Int      @default(1)
  difficulty  String   @default("EASY")
  qualityRating Int?
  actualHours Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee? @relation(fields: [employeeId], references: [id])
  team        Team?     @relation(fields: [teamId], references: [id])
}

model Payroll {
  id                  String    @id @default(uuid())
  employeeId          String
  month               Int
  year                Int
  basicSalary         Float
  overtime            Float     @default(0)
  bonuses             Float     @default(0)
  pph21               Float     @default(0)
  bpjsKetenagakerjaan Float     @default(0)
  bpjsKesehatan       Float     @default(0)
  lateDeduction       Float     @default(0)
  otherDeductions     Float     @default(0)
  netSalary           Float
  status              String    @default("PENDING")
  paymentDate         DateTime?
  payslipUrl          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  employee            Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
}

model Notification {
  id         String   @id @default(uuid())
  employeeId String
  title      String
  message    String
  type       String   @default("INFO")
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model FaceMetadata {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  faceEncoding String
  lastUpdated  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id])
}

model AttendanceCorrection {
  id              String   @id @default(uuid())
  employeeId      String
  attendanceId    String?
  oldClockIn      DateTime?
  oldClockOut     DateTime?
  requestedDate   DateTime
  requestedClockIn DateTime?
  requestedClockOut DateTime?
  reason          String
  status          String   @default("PENDING")
  adminNote       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee   Employee    @relation(fields: [employeeId], references: [id])
  attendance Attendance? @relation(fields: [attendanceId], references: [id])
}

model Team {
  id          String       @id @default(uuid())
  name        String
  description String?
  leaderId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  leader      Employee     @relation("TeamLeader", fields: [leaderId], references: [id])
  members     TeamMember[]
  tasks       Task[]
}

model TeamMember {
  teamId     String
  employeeId String
  team       Team     @relation(fields: [teamId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@id([teamId, employeeId])
}

model Overtime {
  id               String    @id @default(uuid())
  employeeId       String
  date             DateTime
  startTime        DateTime  // Jam mulai rencana
  endTime          DateTime  // Jam selesai rencana
  actualStart      DateTime? // Jam clock-in wajah sesungguhnya
  actualEnd        DateTime? // Jam clock-out wajah sesungguhnya
  reason           String
  status           String    @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  adminNote        String?
  compensation     Float     @default(0)
  duration         Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  employee         Employee  @relation(fields: [employeeId], references: [id])
}

model KpiReview {
  id              String   @id @default(uuid())
  employeeId      String
  reviewerId      String
  month           Int
  year            Int
  taskScore       Float    @default(0)
  attendanceScore Float    @default(0)
  behavioralScore Float    @default(0)
  overallScore    Float    @default(0)
  comment         String?
  status          String   @default("DRAFT") // DRAFT, FINAL
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        Employee    @relation(fields: [employeeId], references: [id])
  metrics         KpiMetric[]

  @@unique([employeeId, month, year])
}

model KpiMetric {
  id          String    @id @default(uuid())
  kpiReviewId String
  name        String    // e.g., "Discipline", "Teamwork", "Communication"
  score       Float     @default(0)
  kpiReview   KpiReview @relation(fields: [kpiReviewId], references: [id], onDelete: Cascade)
}

model KpiCriteria {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reimbursement {
  id          String   @id @default(uuid())
  employeeId  String
  title       String
  description String?
  category    String   // e.g., Transport, Food, Medical, Office
  amount      Float
  date        DateTime
  receiptUrl  String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id])
}

